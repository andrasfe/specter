{"program_id": "COACTUPC", "paragraphs": [{"name": "0000-MAIN", "line_start": 859, "line_end": 1005, "statements": [{"type": "EXEC_CICS", "text": "EXEC CICS HANDLE ABEND LABEL(ABEND-ROUTINE) END-EXEC", "line_start": 862, "line_end": 864, "attributes": {"raw_text": "EXEC CICS HANDLE ABEND LABEL(ABEND-ROUTINE) END-EXEC"}, "children": []}, {"type": "INITIALIZE", "text": "INITIALIZE CC-WORK-AREA\nWS-MISC-STORAGE\nWS-COMMAREA", "line_start": 866, "line_end": 868, "attributes": {}, "children": []}, {"type": "MOVE", "text": "MOVE LIT-THISTRANID       TO WS-TRANID", "line_start": 872, "line_end": 872, "attributes": {"source": "LIT-THISTRANID", "targets": "WS-TRANID"}, "children": []}, {"type": "SET", "text": "SET WS-RETURN-MSG-OFF  TO TRUE", "line_start": 876, "line_end": 876, "attributes": {}, "children": []}, {"type": "IF", "text": "IF EIBCALEN IS EQUAL TO 0\nOR (CDEMO-FROM-PROGRAM = LIT-MENUPGM\nAND NOT CDEMO-PGM-REENTER)", "line_start": 880, "line_end": 882, "attributes": {"condition": "EIBCALEN IS EQUAL TO 0\nOR (CDEMO-FROM-PROGRAM = LIT-MENUPGM\nAND NOT CDEMO-PGM-REENTER)"}, "children": [{"type": "INITIALIZE", "text": "INITIALIZE CARDDEMO-COMMAREA\nWS-THIS-PROGCOMMAREA", "line_start": 883, "line_end": 884, "attributes": {}, "children": []}, {"type": "SET", "text": "SET CDEMO-PGM-ENTER TO TRUE", "line_start": 885, "line_end": 885, "attributes": {}, "children": []}, {"type": "SET", "text": "SET ACUP-DETAILS-NOT-FETCHED TO TRUE", "line_start": 886, "line_end": 886, "attributes": {}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 887, "line_end": 887, "attributes": {}, "children": [{"type": "MOVE", "text": "MOVE DFHCOMMAREA (1:LENGTH OF CARDDEMO-COMMAREA)  TO\nCARDDEMO-COMMAREA", "line_start": 888, "line_end": 889, "attributes": {"source": "DFHCOMMAREA (1:LENGTH OF CARDDEMO-COMMAREA)", "targets": "CARDDEMO-COMMAREA"}, "children": []}, {"type": "UNKNOWN", "text": "MOVE DFHCOMMAREA(LENGTH OF CARDDEMO-COMMAREA + 1:\nLENGTH OF WS-THIS-PROGCOMMAREA ) TO\nWS-THIS-PROGCOMMAREA", "line_start": 890, "line_end": 892, "attributes": {}, "children": []}]}]}, {"type": "PERFORM_THRU", "text": "PERFORM YYYY-STORE-PFKEY\nTHRU YYYY-STORE-PFKEY-EXIT", "line_start": 898, "line_end": 899, "attributes": {"target": "YYYY-STORE-PFKEY", "thru": "YYYY-STORE-PFKEY-EXIT"}, "children": []}, {"type": "SET", "text": "SET PFK-INVALID TO TRUE", "line_start": 905, "line_end": 905, "attributes": {}, "children": []}, {"type": "IF", "text": "IF CCARD-AID-ENTER OR\nCCARD-AID-PFK03 OR\n(CCARD-AID-PFK05 AND ACUP-CHANGES-OK-NOT-CONFIRMED)\nOR\n(CCARD-AID-PFK12 AND NOT ACUP-DETAILS-NOT-FETCHED)", "line_start": 906, "line_end": 910, "attributes": {"condition": "CCARD-AID-ENTER OR\nCCARD-AID-PFK03 OR\n(CCARD-AID-PFK05 AND ACUP-CHANGES-OK-NOT-CONFIRMED)\nOR\n(CCARD-AID-PFK12 AND NOT ACUP-DETAILS-NOT-FETCHED)"}, "children": [{"type": "SET", "text": "SET PFK-VALID TO TRUE", "line_start": 911, "line_end": 911, "attributes": {}, "children": []}]}, {"type": "IF", "text": "IF PFK-INVALID", "line_start": 914, "line_end": 914, "attributes": {"condition": "PFK-INVALID"}, "children": [{"type": "SET", "text": "SET CCARD-AID-ENTER TO TRUE", "line_start": 915, "line_end": 915, "attributes": {}, "children": []}]}, {"type": "EVALUATE", "text": "EVALUATE TRUE", "line_start": 921, "line_end": 921, "attributes": {"subject": "TRUE"}, "children": [{"type": "WHEN", "text": "WHEN CCARD-AID-PFK03", "line_start": 927, "line_end": 927, "attributes": {"value": "CCARD-AID-PFK03"}, "children": [{"type": "SET", "text": "SET CCARD-AID-PFK03     TO TRUE", "line_start": 928, "line_end": 928, "attributes": {}, "children": []}, {"type": "IF", "text": "IF CDEMO-FROM-TRANID    EQUAL LOW-VALUES\nOR CDEMO-FROM-TRANID    EQUAL SPACES", "line_start": 930, "line_end": 931, "attributes": {"condition": "CDEMO-FROM-TRANID    EQUAL LOW-VALUES\nOR CDEMO-FROM-TRANID    EQUAL SPACES"}, "children": [{"type": "MOVE", "text": "MOVE LIT-MENUTRANID  TO CDEMO-TO-TRANID", "line_start": 932, "line_end": 932, "attributes": {"source": "LIT-MENUTRANID", "targets": "CDEMO-TO-TRANID"}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 933, "line_end": 933, "attributes": {}, "children": [{"type": "MOVE", "text": "MOVE CDEMO-FROM-TRANID  TO CDEMO-TO-TRANID", "line_start": 934, "line_end": 934, "attributes": {"source": "CDEMO-FROM-TRANID", "targets": "CDEMO-TO-TRANID"}, "children": []}]}]}, {"type": "IF", "text": "IF CDEMO-FROM-PROGRAM   EQUAL LOW-VALUES\nOR CDEMO-FROM-PROGRAM   EQUAL SPACES", "line_start": 937, "line_end": 938, "attributes": {"condition": "CDEMO-FROM-PROGRAM   EQUAL LOW-VALUES\nOR CDEMO-FROM-PROGRAM   EQUAL SPACES"}, "children": [{"type": "MOVE", "text": "MOVE LIT-MENUPGM     TO CDEMO-TO-PROGRAM", "line_start": 939, "line_end": 939, "attributes": {"source": "LIT-MENUPGM", "targets": "CDEMO-TO-PROGRAM"}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 940, "line_end": 940, "attributes": {}, "children": [{"type": "MOVE", "text": "MOVE CDEMO-FROM-PROGRAM TO CDEMO-TO-PROGRAM", "line_start": 941, "line_end": 941, "attributes": {"source": "CDEMO-FROM-PROGRAM", "targets": "CDEMO-TO-PROGRAM"}, "children": []}]}]}, {"type": "MOVE", "text": "MOVE LIT-THISTRANID     TO CDEMO-FROM-TRANID", "line_start": 944, "line_end": 944, "attributes": {"source": "LIT-THISTRANID", "targets": "CDEMO-FROM-TRANID"}, "children": []}, {"type": "MOVE", "text": "MOVE LIT-THISPGM        TO CDEMO-FROM-PROGRAM", "line_start": 945, "line_end": 945, "attributes": {"source": "LIT-THISPGM", "targets": "CDEMO-FROM-PROGRAM"}, "children": []}, {"type": "SET", "text": "SET  CDEMO-USRTYP-USER  TO TRUE", "line_start": 947, "line_end": 947, "attributes": {}, "children": []}, {"type": "SET", "text": "SET  CDEMO-PGM-ENTER    TO TRUE", "line_start": 948, "line_end": 948, "attributes": {}, "children": []}, {"type": "MOVE", "text": "MOVE LIT-THISMAPSET     TO CDEMO-LAST-MAPSET", "line_start": 949, "line_end": 949, "attributes": {"source": "LIT-THISMAPSET", "targets": "CDEMO-LAST-MAPSET"}, "children": []}, {"type": "MOVE", "text": "MOVE LIT-THISMAP        TO CDEMO-LAST-MAP", "line_start": 950, "line_end": 950, "attributes": {"source": "LIT-THISMAP", "targets": "CDEMO-LAST-MAP"}, "children": []}, {"type": "EXEC_CICS", "text": "EXEC CICS SYNCPOINT END-EXEC", "line_start": 952, "line_end": 954, "attributes": {"raw_text": "EXEC CICS SYNCPOINT END-EXEC"}, "children": []}, {"type": "EXEC_CICS", "text": "EXEC CICS XCTL PROGRAM (CDEMO-TO-PROGRAM) COMMAREA(CARDDEMO-COMMAREA) END-EXEC", "line_start": 956, "line_end": 959, "attributes": {"raw_text": "EXEC CICS XCTL PROGRAM (CDEMO-TO-PROGRAM) COMMAREA(CARDDEMO-COMMAREA) END-EXEC"}, "children": []}]}, {"type": "WHEN", "text": "WHEN ACUP-DETAILS-NOT-FETCHED\nAND CDEMO-PGM-ENTER", "line_start": 964, "line_end": 965, "attributes": {"value": "ACUP-DETAILS-NOT-FETCHED\nAND CDEMO-PGM-ENTER"}, "children": []}, {"type": "WHEN", "text": "WHEN CDEMO-FROM-PROGRAM   EQUAL LIT-MENUPGM\nAND NOT CDEMO-PGM-REENTER", "line_start": 966, "line_end": 967, "attributes": {"value": "CDEMO-FROM-PROGRAM   EQUAL LIT-MENUPGM\nAND NOT CDEMO-PGM-REENTER"}, "children": [{"type": "INITIALIZE", "text": "INITIALIZE WS-THIS-PROGCOMMAREA", "line_start": 968, "line_end": 968, "attributes": {}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 3000-SEND-MAP THRU\n3000-SEND-MAP-EXIT", "line_start": 969, "line_end": 970, "attributes": {"target": "3000-SEND-MAP", "thru": "3000-SEND-MAP-EXIT"}, "children": []}, {"type": "SET", "text": "SET CDEMO-PGM-REENTER        TO TRUE", "line_start": 971, "line_end": 971, "attributes": {}, "children": []}, {"type": "SET", "text": "SET ACUP-DETAILS-NOT-FETCHED TO TRUE", "line_start": 972, "line_end": 972, "attributes": {}, "children": []}, {"type": "GO_TO", "text": "GO TO COMMON-RETURN", "line_start": 973, "line_end": 973, "attributes": {"target": "COMMON-RETURN"}, "children": []}]}, {"type": "WHEN", "text": "WHEN ACUP-CHANGES-OKAYED-AND-DONE", "line_start": 979, "line_end": 979, "attributes": {"value": "AC